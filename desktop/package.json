{
  "name": "data-reconciler",
  "version": "0.4.0",
  "description": "Data Reconciliation Tool — compare databases, find discrepancies",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder",
    "dist:linux": "electron-builder --linux",
    "dist:mac": "electron-builder --mac",
    "dist:win": "electron-builder --win"
  },
  "dependencies": {
    "electron-updater": "^6.1.0"
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0"
  },
  "build": {
    "appId": "com.sergey.data-reconciler",
    "productName": "Data Reconciler",
    "directories": {
      "output": "release"
    },
    "extraResources": [
      {
        "from": "../bin/${os}/",
        "to": "backend",
        "filter": ["**/*"]
      },
      {
        "from": "../web/dist/",
        "to": "frontend",
        "filter": ["**/*"]
      }
    ],
    "publish": {
      "provider": "github",
      "owner": "zerezhka",
      "repo": "data-reconcilation"
    },
    "mac": {
      "target": ["dmg", "zip"],
      "category": "public.app-category.developer-tools"
    },
    "win": {
      "target": ["nsis"]
    },
    "linux": {
      "target": ["AppImage", "deb"],
      "category": "Development"
    }
  }
}
