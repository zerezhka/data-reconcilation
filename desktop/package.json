{
  "name": "data-reconciler",
  "version": "0.5.0",
  "description": "Data Reconciliation Tool — compare databases, find discrepancies",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder",
    "dist:linux": "electron-builder --linux",
    "dist:mac": "electron-builder --mac",
    "dist:win": "electron-builder --win"
  },
  "dependencies": {
    "tar": "^7.0.0"
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0"
  },
  "build": {
    "appId": "com.sergey.data-reconciler",
    "productName": "Data Reconciler",
    "directories": {
      "output": "release"
    },
    "files": [
      "main.js",
      "preload.js",
      "backend.js",
      "downloader.js",
      "updater.js",
      "node_modules/**/*"
    ],
    "publish": {
      "provider": "github",
      "owner": "zerezhka",
      "repo": "data-reconcilation"
    },
    "mac": {
      "target": ["dmg", "zip"],
      "category": "public.app-category.developer-tools"
    },
    "win": {
      "target": ["nsis"]
    },
    "linux": {
      "target": ["AppImage", "tar.gz"],
      "category": "Development"
    }
  }
}
